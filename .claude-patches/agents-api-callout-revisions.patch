+    import os, requests
+
+    BASE = "https://api.us.poly.ai"
+    HEADERS = {"x-api-key": os.environ["POLYAI_API_KEY"]}
+
+    # Sync all FAQ entries from your CMS into PolyAI topics
+    for faq in cms.list_faqs():
